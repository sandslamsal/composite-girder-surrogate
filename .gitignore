# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
.env

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
*.egg-info/
*.egg

# Jupyter
.ipynb_checkpoints/

# PyTorch / model artefacts -- keep released weights, exclude scratch.
# Patterns are **/-prefixed so they apply inside the Paper 1/ subtree too.
*.pt
*.pth
*.ckpt
*.pt.bak
checkpoints/
runs/
wandb/
!**/weights/headline_model.pt
!**/weights/*.pt
# local backups of superseded models -- not part of the release
**/weights/archive_*/

# Data -- keep the smoke-test sample; exclude the full LHS sweep,
# intermediate processed parquets, and run reports.
**/data/raw/
**/data/processed/
**/data/full/
**/data/*.npz
**/data/*.h5
reports/

# Generated figures (output target, not checked in)
**/figures/*.png
**/figures/*.pdf
**/figures/validation/

# Paper-writing -- this is a CODE repository only. The manuscript,
# cover letter, highlights, and text-addition notes are kept elsewhere.
paper/
paper1_text_additions.md
*_text_additions.md

# Paper 2 -- maintained in its own separate repository.
paper2-beam-level/

# Archives (e.g. Paper 1.zip) -- never committed
*.zip

# Logs / temp
*.log
*.out
*.tcl.log

# Notebooks / tests (empty)
notebooks/
tests/

# OS
.DS_Store
Thumbs.db
~$*
*.swp

# Editor / IDE
.vscode/
.idea/
.vs/

# AI tool configs -- must not be committed
.claude/
.cursor/
.aider*
.continue/
.copilot/

# Proposal / private docs
*.docx

# Zenodo upload staging -- heavy artefacts uploaded manually, not via git
zenodo_upload/
